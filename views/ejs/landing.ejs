<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nimbus SaaS UI</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <div class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-16 top-0 h-64 w-64 rounded-full bg-cyan-400/25 blur-3xl"></div>
        <div class="absolute right-0 top-20 h-80 w-80 rounded-full bg-sky-300/20 blur-3xl"></div>
      </div>

      <main class="relative z-10 mx-auto max-w-6xl px-6 py-14 lg:py-20">
        <section class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div>
            <span class="inline-flex items-center rounded-full border border-cyan-300/30 bg-cyan-400/10 px-3 py-1 text-xs font-semibold tracking-wide text-cyan-200">
              New: AI workflow templates
            </span>
            <h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
              Build, launch, and scale your SaaS with confidence.
            </h1>
            <p class="mt-4 max-w-xl text-base leading-7 text-slate-300">
              A clean dashboard stack for product teams. Manage users, automate flows, and monitor growth in one focused workspace.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <% (heroButtonsHtml || []).forEach((buttonHtml) => { %>
                <%- buttonHtml %>
              <% }); %>
            </div>
          </div>

          <div class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-slate-950/50 backdrop-blur-md">
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div class="rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-slate-400">MRR</p>
                <p class="mt-2 text-2xl font-bold">$42,180</p>
                <p class="mt-1 text-cyan-300">+18.2% this month</p>
              </div>
              <div class="rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-slate-400">Active teams</p>
                <p class="mt-2 text-2xl font-bold">1,248</p>
                <p class="mt-1 text-cyan-300">+154 this week</p>
              </div>
              <div class="col-span-2 rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-slate-400">Automation success rate</p>
                <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-700">
                  <div class="h-full w-[84%] rounded-full bg-cyan-300"></div>
                </div>
                <p class="mt-2 text-sm text-slate-300">84% workflows completed without manual action</p>
              </div>
            </div>
          </div>
        </section>

        <section id="pricing" class="mt-16 lg:mt-20">
          <div class="mb-6 flex items-end justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-wider text-cyan-200">Pricing</p>
              <h2 class="mt-2 text-3xl font-bold tracking-tight">Plans for every growth stage</h2>
            </div>
          </div>

          <div class="grid gap-5 md:grid-cols-3">
            <% (planCardsHtml || []).forEach((cardHtml) => { %>
              <%- cardHtml %>
            <% }); %>
          </div>
        </section>
      </main>
    </div>
  </body>
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</html>
