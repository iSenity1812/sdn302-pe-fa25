<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Foods - Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="min-h-screen bg-slate-50">
    <nav class="border-b border-slate-200 bg-white shadow-sm">
      <div class="mx-auto max-w-7xl px-6 py-4">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-bold text-slate-900">Dashboard</h1>
          <a href="/auth/logout" class="text-sm font-semibold text-slate-600 hover:text-slate-900">
            Logout
          </a>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-6 py-12">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h2 class="text-3xl font-bold text-slate-900">All Foods</h2>
          <p class="mt-2 text-slate-600">
            Browse our comprehensive collection of foods from around the world
          </p>
        </div>
        <button
          onclick="document.getElementById('createFoodModal').classList.remove('hidden')"
          class="rounded-lg bg-cyan-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-cyan-700 transition"
        >
          ➕ Create Food
        </button>
      </div>

      <% if (errors && Object.keys(errors).length > 0) { %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4">
          <h3 class="font-semibold text-red-700 mb-3">Validation Errors:</h3>
          <ul class="space-y-2">
            <% Object.entries(errors).forEach(([key, message]) => { %>
              <li class="text-sm text-red-700">• <%= message %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% (foodCardsHtml || []).forEach((cardHtml) => { %>
          <%- cardHtml %>
        <% }); %>
      </div>

      <% if (foods && foods.length === 0) { %>
        <div class="rounded-lg border border-slate-200 bg-white p-12 text-center">
          <p class="text-slate-600">No foods found</p>
        </div>
      <% } %>
    </main>

    <!-- Create Food Modal -->
    <div id="createFoodModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50">
      <div class="relative w-full max-w-md rounded-2xl bg-white p-8 shadow-2xl">
        <button
          type="button"
          onclick="document.getElementById('createFoodModal').classList.add('hidden')"
          class="absolute right-4 top-4 text-slate-400 transition hover:text-slate-600"
        >
          <span class="text-2xl">&times;</span>
        </button>

        <h2 class="mb-1 text-2xl font-bold text-slate-900">Create New Food</h2>
        <p class="mb-6 text-sm text-slate-600">Add a new food to your collection</p>

        <form action="/page/foods" method="POST" class="space-y-4">
          <!-- Food Name -->
          <div class="flex flex-col gap-1.5">
            <label for="foodName" class="block text-sm font-semibold text-slate-700">Food Name *</label>
            <input
              type="text"
              id="foodName"
              name="foodName"
              placeholder="e.g., Spaghetti Carbonara"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-500 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              pattern="[a-zA-Z\s]+"
              required
              value="<%= formData?.foodName || '' %>"
            />
            <% if (errors?.foodName) { %>
              <p class="text-xs text-red-600"><%= errors.foodName %></p>
            <% } %>
            <p class="text-xs text-slate-500">Letters and spaces only</p>
          </div>

          <!-- Calories -->
          <div class="flex flex-col gap-1.5">
            <label for="calories" class="block text-sm font-semibold text-slate-700">Calories *</label>
            <input
              type="number"
              id="calories"
              name="calories"
              placeholder="e.g., 950"
              min="700"
              max="1500"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-500 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              required
              value="<%= formData?.calories || '' %>"
            />
            <% if (errors?.calories) { %>
              <p class="text-xs text-red-600"><%= errors.calories %></p>
            <% } %>
            <p class="text-xs text-slate-500">Between 700 and 1500</p>
          </div>

          <!-- Food Description -->
          <div class="flex flex-col gap-1.5">
            <label for="foodDescription" class="block text-sm font-semibold text-slate-700">Food Description *</label>
            <textarea
              id="foodDescription"
              name="foodDescription"
              placeholder="Describe this food..."
              rows="3"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-500 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              required
            ><%= formData?.foodDescription || '' %></textarea>
            <% if (errors?.foodDescription) { %>
              <p class="text-xs text-red-600"><%= errors.foodDescription %></p>
            <% } %>
          </div>

          <!-- Image URL -->
          <div class="flex flex-col gap-1.5">
            <label for="imageUrl" class="block text-sm font-semibold text-slate-700">Image URL *</label>
            <input
              type="url"
              id="imageUrl"
              name="imageUrl"
              placeholder="https://example.com/image.jpg"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-500 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              required
              value="<%= formData?.imageUrl || '' %>"
            />
            <% if (errors?.imageUrl) { %>
              <p class="text-xs text-red-600"><%= errors.imageUrl %></p>
            <% } %>
          </div>

          <!-- Rating -->
          <div class="flex flex-col gap-1.5">
            <label for="rating" class="block text-sm font-semibold text-slate-700">Rating *</label>
            <input
              type="number"
              id="rating"
              name="rating"
              min="1"
              max="5"
              step="1"
              placeholder="Enter rating 1 to 5"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              required
              value="<%= formData?.rating || '' %>"
            />
            <% if (errors?.rating) { %>
              <p class="text-xs text-red-600"><%= errors.rating %></p>
            <% } %>
            <p class="text-xs text-slate-500">Enter a number from 1 to 5</p>
          </div>

          <!-- Nation -->
          <div class="flex flex-col gap-1.5">
            <label for="nation" class="block text-sm font-semibold text-slate-700">Nation *</label>
            <select
              id="nation"
              name="nation"
              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 transition focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30"
              required
            >
              <option value="">Select a nation</option>
              <% if (nations && nations.length > 0) { %>
                <% nations.forEach((nation) => { %>
                  <option value="<%= nation._id %>" <% if (formData?.nation == nation._id) { %>selected<% } %>>
                    <%= nation.nationName %>
                  </option>
                <% }); %>
              <% } %>
            </select>
            <% if (errors?.nation) { %>
              <p class="text-xs text-red-600"><%= errors.nation %></p>
            <% } %>
          </div>

          <!-- Is Vegetarian Toggle -->
          <div class="flex flex-col gap-3 py-2">
            <label class="block text-sm font-semibold text-slate-700">Is Vegetarian?</label>
            <div class="flex items-center gap-3">
              <input
                type="checkbox"
                id="isVegetarian"
                name="isVegetarian"
                class="h-5 w-5 rounded border-slate-300 text-cyan-600 transition focus:ring-2 focus:ring-cyan-300/30 cursor-pointer"
                <% if (formData?.isVegetarian == 'on' || formData?.isVegetarian == true) { %>checked<% } %>
              />
              <label for="isVegetarian" class="cursor-pointer text-sm text-slate-700">
                Vegetarian
              </label>
            </div>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800"
          >
            Create Food
          </button>

          <!-- Cancel Button -->
          <button
            type="button"
            onclick="document.getElementById('createFoodModal').classList.add('hidden')"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
          >
            Cancel
          </button>
        </form>
      </div>
    </div>

    <script>
      // Close modal when clicking outside
      document.getElementById('createFoodModal').addEventListener('click', function(e) {
        if (e.target === this) {
          this.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
