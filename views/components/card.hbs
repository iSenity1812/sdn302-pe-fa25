<article class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
	{{#if accent}}
		<div class="pointer-events-none absolute -right-8 -top-8 h-28 w-28 rounded-full blur-2xl {{accent}}"></div>
	{{/if}}

	<div class="relative z-10 flex h-full flex-col">
		{{#if badge}}
			<div class="mb-4 flex items-center justify-between gap-3">
				<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{badgeClass}}">{{badge}}</span>
				{{#if price}}
					<span class="text-sm font-semibold text-slate-500">{{price}}</span>
				{{/if}}
			</div>
		{{else}}
			{{#if price}}
				<div class="mb-4 flex justify-end">
					<span class="text-sm font-semibold text-slate-500">{{price}}</span>
				</div>
			{{/if}}
		{{/if}}

		<h3 class="text-xl font-bold tracking-tight text-slate-900 truncate">{{title}}</h3>

		{{#if description}}
			<p class="mt-2 text-sm leading-6 text-slate-600">{{description}}</p>
		{{/if}}

		{{#if points}}
			<ul class="mt-5 space-y-2 text-sm text-slate-600">
				{{#each points}}
					<li class="flex items-start gap-2">
						<span class="mt-0.5 text-cyan-600">●</span>
						<span>{{this}}</span>
					</li>
				{{/each}}
			</ul>
		{{/if}}

		{{#if ctaLabel}}
			<div class="mt-6">
				<a
					href="{{ctaHref}}"
					class="inline-flex w-full items-center justify-center rounded-xl px-4 py-2.5 text-sm font-semibold text-white transition {{ctaClass}}"
				>
					{{ctaLabel}}
				</a>
			</div>
		{{/if}}

		{{#if @partial-block}}
			<div class="mt-6">
				{{> @partial-block}}
			</div>
		{{/if}}
	</div>
</article>
