<ul class="space-y-2">
	{{#each items}}
		<li class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-4 transition hover:border-slate-300 hover:shadow-sm">
			{{#if icon}}
				<span class="text-lg text-slate-600">{{icon}}</span>
			{{/if}}
			<div class="flex-1">
				{{#if title}}
					<p class="font-semibold text-slate-900">{{title}}</p>
				{{/if}}
				{{#if description}}
					<p class="text-sm text-slate-600">{{description}}</p>
				{{/if}}
			</div>
			{{#if badge}}
				<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{badgeClass}}">
					{{badge}}
				</span>
			{{/if}}
		</li>
	{{/each}}
</ul>
